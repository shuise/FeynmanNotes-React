{
  "name": "feynman-notes",
  "displayName": "费曼笔记",
  "version": "0.0.1",
  "description": "费曼笔记 - 笔记并不是思考的过程，笔记就是思考本身",
  "author": "Blockfish",
  "scripts": {
    "dev": "plasmo dev --verbose",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "alias": {
    "react": "./src/vendor/react-global.ts",
    "react-dom/client": "./src/vendor/react-dom-global.ts",
    "react/jsx-runtime": "./src/vendor/react-jsx-runtime.ts",
    "react-native": "react-native-web"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@reduxjs/toolkit": "2.0.1",
    "@swc/core": "1.5.7",
    "blueimp-md5": "^2.19.0",
    "html2canvas": "^1.4.1",
    "lodash": "^4.17.21",
    "plasmo": "^0.90.5",
    "qrcode": "^1.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.30.3",
    "redux": "5.0.1",
    "redux-thunk": "3.1.0",
    "turndown": "^7.2.2",
    "underscore": "^1.13.7",
    "web3": "^4.8.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "5.3.3"
  },
  "pnpm": {
    "overrides": {
      "jiti": "1.16.0"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "manifest": {
    "permissions": ["cookies"],
    "host_permissions": ["<all_urls>"],
    "action": {
      "default_popup": "../popup.html",
      "default_title": "Feynman 笔记"
    }
  }
}
